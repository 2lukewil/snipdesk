# Local signing config for `npm run tauri:build` and `npm run tauri:build:teams`.
#
# Copy this file to `.env` and fill in your local values. The real `.env`
# is gitignored and never leaves your machine. CI gets these as GitHub
# Secrets in .github/workflows/release.yml; this file is for local builds
# only.
#
# Without these, Tauri's bundler still runs but errors at the signing step
# (because tauri.conf.json has createUpdaterArtifacts: true). With them,
# you get the same .sig files CI produces.

# Path to the Ed25519 private key file generated by:
#   npx @tauri-apps/cli signer generate -w $HOME/.snipdesk-update.key
# Use this OR TAURI_SIGNING_PRIVATE_KEY below — not both. Path is simpler
# because the file content has line breaks that .env parsers handle poorly.
TAURI_SIGNING_PRIVATE_KEY_PATH=C:\Users\YourName\.snipdesk-update.key

# Alternative: paste the file contents inline, wrapped in double quotes so
# the .env parser keeps the line breaks. Comment out the PATH above if you
# use this. Leave commented out otherwise.
# TAURI_SIGNING_PRIVATE_KEY="untrusted comment: minisign encrypted secret key
# RWRTY...
# RWRTY..."

# The passphrase you chose when running `signer generate`. Required to
# decrypt the private key during signing.
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=your-passphrase-here
